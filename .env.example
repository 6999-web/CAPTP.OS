# Runtime profile: cpu or gpu
CAPTP_RUNTIME_PROFILE=cpu
CAPTP_HOST=127.0.0.1
CAPTP_PORT=8000
CAPTP_SCENE_CARDINALITY=multi_person

# Model paths
YOLO_POSE_MODEL=yolov8n-pose.pt
YOLO_WEAPON_MODEL=
MMPOSE_CONFIG=
MMPOSE_CHECKPOINT=
MMACTION_CONFIG=
MMACTION_CHECKPOINT=

# Low-power profile tuning (Orange Pi friendly)
MEDIAPIPE_MODEL_COMPLEXITY=1
MEDIAPIPE_FRAME_SKIP=0

# GitHub reference image whitelist (comma-separated raw.githubusercontent URLs)
GITHUB_REFERENCE_SOURCES=https://raw.githubusercontent.com/google-ai-edge/mediapipe/master/docs/images/pose_tracking_full_body_landmarks.png,https://raw.githubusercontent.com/ultralytics/ultralytics/main/docs/en/images/tasks/pose.jpg
REFERENCE_IMAGE_FALLBACK=/school_badge.jpg

# Optional cloud reasoning bridge
REASONING_BRIDGE_ENABLED=false
REASONING_PROVIDER=openai
REASONING_BASE_URL=
REASONING_MODEL=
REASONING_API_KEY=

# Legacy optional keys
NVIDIA_API_KEY=
VISION_PRIMARY_KEY=
PARSER_NODE_KEY=
REWARD_SCORING_KEY=

