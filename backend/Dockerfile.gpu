# CUDA base image; adjust tag to your host CUDA driver compatibility
FROM nvidia/cuda:12.1.1-cudnn8-runtime-ubuntu22.04

WORKDIR /app
ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV CAPTP_RUNTIME_PROFILE=gpu

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv \
    libgl1 libglib2.0-0 build-essential \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.gpu.txt /app/requirements.gpu.txt
RUN python3 -m pip install --no-cache-dir --upgrade pip && python3 -m pip install --no-cache-dir -r /app/requirements.gpu.txt

COPY backend /app/backend
WORKDIR /app/backend

EXPOSE 6063
CMD ["python3", "-m", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "6063"]

